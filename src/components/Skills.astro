---
import skillsData from '../data/skills.json';
import { withBase } from '../lib/assetPath';
---

<section id="skills" class="py-24" style="scroll-margin-top: 80px;">
  <div class="container mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16 reveal">
      <p class="text-sm font-semibold tracking-widest text-highlight uppercase mb-3">
        What I work with
      </p>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-bold section-title">Tools & Skills</h2>
    </div>

    <div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-8">
      {
        skillsData.map((category, ci) => (
          <div class="card reveal" style={`transition-delay: ${ci * 0.1}s;`}>
            <h3 class="text-sm font-bold mb-6 text-accent uppercase tracking-widest">
              {category.title}
            </h3>

            <div class="skill-grid">
              {category.skills.map((skill) => (
                <div class="skill-item">
                  <img
                    src={withBase(skill.logo)}
                    alt={skill.name}
                    class="skill-icon"
                    loading="lazy"
                    width="36"
                    height="36"
                  />
                  <span class="skill-name">{skill.name}</span>
                </div>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .skill-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(72px, 1fr));
    gap: 1.25rem 0.75rem;
  }

  .skill-item {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    text-align: center;
    transition: transform 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .skill-item:hover {
    transform: translateY(-3px) scale(1.08);
  }

  .skill-item::after {
    content: '';
    position: absolute;
    top: 2px;
    left: 50%;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    transform: translateX(-50%);
    background: conic-gradient(from 0deg, #e0e7ff, #f0f9ff, #fdf4ff, #e0e7ff);
    filter: blur(10px);
    opacity: 0;
    z-index: 0;
    animation: skill-glow-spin 4s linear infinite;
    animation-play-state: paused;
    transition: opacity 0.12s ease;
  }
  .skill-item:hover::after {
    opacity: 0.12;
    animation-play-state: running;
    transition: opacity 0.75s ease;
  }

  @keyframes skill-glow-spin {
    from {
      transform: translateX(-50%) rotate(0deg);
    }
    to {
      transform: translateX(-50%) rotate(360deg);
    }
  }

  .skill-icon {
    position: relative;
    z-index: 1;
    width: 36px;
    height: 36px;
    object-fit: contain;
    filter: brightness(0.85) saturate(0.8);
    transition: filter 0.2s ease;
  }
  .skill-item:hover .skill-icon {
    filter: brightness(1.1) saturate(1.2);
  }

  .skill-name {
    position: relative;
    z-index: 1;
    font-size: 0.65rem;
    font-weight: 500;
    color: #64748b;
    line-height: 1.2;
    transition:
      color 0.2s ease,
      text-shadow 0.2s ease;
  }
  .skill-item:hover .skill-name {
    color: #94a3b8;
    text-shadow: 0px 1px 1px black;
  }
</style>

<script>
  document.querySelectorAll('#skills .reveal').forEach((el) => {
    const io = new IntersectionObserver(
      ([entry]) => {
        if (entry.isIntersecting) {
          el.classList.add('visible');
          io.disconnect();
        }
      },
      { threshold: 0.1 }
    );
    io.observe(el);
  });
</script>
